# ─── Microsoft Entra ID (MSAL) ───────────────────────────────────────────────
# Azure AD app registration client ID for the frontend SPA
VITE_MSAL_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Azure AD tenant ID (BlinkCharging.com tenant)
VITE_MSAL_TENANT_ID=00000000-0000-0000-0000-000000000000

# Redirect URI after Entra ID login — must match App Registration reply URLs
# Local: http://localhost:5173/auth/callback
# Staging: https://blink-relay-api-staging.azurewebsites.net/auth/callback
# Prod:    https://blink-relay-api.azurewebsites.net/auth/callback
VITE_MSAL_REDIRECT_URI=http://localhost:5173/auth/callback

# ─── Backend API ──────────────────────────────────────────────────────────────
# Base URL of the FastAPI backend
# Local:   http://localhost:8000
# Staging: https://blink-relay-api-staging.azurewebsites.net
# Prod:    https://blink-relay-api.azurewebsites.net
VITE_API_BASE_URL=http://localhost:8000

# ─── Application ─────────────────────────────────────────────────────────────
# Environment tag shown in UI — local | staging | production
VITE_ENVIRONMENT=local

# Application Insights connection string (optional for local dev)
VITE_APPINSIGHTS_CONNECTION_STRING=
