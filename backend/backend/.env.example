# ─── Application ─────────────────────────────────────────────────────────────
# local | staging | production — controls Key Vault loading, CORS, debug mode
ENVIRONMENT=local

# Semantic version surfaced by /health endpoint
APP_VERSION=1.0.0

# Allowed frontend origin for CORS (comma-separated for multiple)
FRONTEND_URL=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL asyncpg connection string
# Format: postgresql+asyncpg://user:password@host:5432/dbname?ssl=require
# Production: loaded from Azure Key Vault secret "DATABASE-URL"
DATABASE_URL=postgresql+asyncpg://blinkadmin:password@localhost:5432/blinkrelaydb

# ─── Redis ───────────────────────────────────────────────────────────────────
# Redis connection string (used by Celery broker + session cache)
# Production: loaded from Azure Key Vault secret "REDIS-URL"
REDIS_URL=redis://localhost:6379/0

# ─── Microsoft Entra ID ──────────────────────────────────────────────────────
# Azure AD tenant ID — same across all environments
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Client ID of the backend app registration
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client secret — only used in local dev (prod uses Managed Identity)
# Production: leave blank; Managed Identity is used instead
AZURE_CLIENT_SECRET=

# ─── Azure Storage ───────────────────────────────────────────────────────────
# Full connection string for blinkrelayfiles storage account
# Production: loaded from Azure Key Vault secret "AZURE-STORAGE-CONNECTION-STRING"
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=blinkrelayfiles;AccountKey=xxx;EndpointSuffix=core.windows.net

# Blob container for request attachments
AZURE_STORAGE_CONTAINER=attachments

# ─── Azure Key Vault ─────────────────────────────────────────────────────────
# Key Vault URI — only needed in staging/production
# Local dev: leave blank (secrets loaded from .env directly)
AZURE_KEY_VAULT_URI=https://kv-blink-relay.vault.azure.net/

# ─── Azure App Configuration ─────────────────────────────────────────────────
# Connection string for appconfig-blink-relay
# Production: loaded from Azure Key Vault secret "APP-CONFIG-CONNECTION-STRING"
APP_CONFIG_CONNECTION_STRING=

# ─── Application Insights ────────────────────────────────────────────────────
# Connection string for Azure Application Insights
# Leave blank to disable telemetry in local dev
APPINSIGHTS_CONNECTION_STRING=

# ─── Jira Integration ────────────────────────────────────────────────────────
# Jira Cloud base URL
JIRA_BASE_URL=https://blinkcharging.atlassian.net

# Jira service account email
JIRA_EMAIL=blink-relay-bot@blinkcharging.com

# Jira API token (created at id.atlassian.com → Security → API tokens)
# Production: loaded from Azure Key Vault
JIRA_API_TOKEN=

# HMAC secret used to verify incoming Jira webhooks
JIRA_WEBHOOK_SECRET=

# Jira project keys per POD — maps Blink Relay POD to Jira project
JIRA_PROJECT_CHARGER=CHG
JIRA_PROJECT_DRIVER=DRV
JIRA_PROJECT_REVENUE=REV
JIRA_PROJECT_DATA=DAT
JIRA_PROJECT_DEVOPS=OPS
JIRA_PROJECT_DENALI=DNL

# ─── Microsoft Graph / Teams ─────────────────────────────────────────────────
# Graph API base URL (rarely needs changing)
GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0

# Teams webhook URL for PM notifications (per-POD webhooks set in App Config)
TEAMS_WEBHOOK_URL=
